# Ghostty configuration — managed by Ansible (workenv/roles/ghostty)

# Font
font-family = SauceCodePro Nerd Font
font-size = 12

# Cursor: blinking block
cursor-style = block
cursor-style-blink = true
# Ghostty's shell-integration "cursor" feature installs zsh zle widgets that
# force a bar cursor at the prompt (overriding cursor-style and the
# powerlevel10k precmd escape). Disable just that feature so the block cursor
# sticks at the prompt; nvim/claude set their own shape and are unaffected.
shell-integration-features = no-cursor

# Colorscheme
theme = Solarized Dark Patched

# Splits appearance
# Bright Solarized base1 so the divider between panes is clearly visible
# against the dark background.
split-divider-color = #93a1a1
# Dim unfocused splits to a 40% blackout so the focused pane stands out
# (opacity 0.6 = 40% of the black fill blended over the unfocused pane).
unfocused-split-opacity = 0.6
# Pure black blended over unfocused splits for the blackout effect.
unfocused-split-fill = #000000

# Automatic updates (macOS / Sparkle; ignored on Linux builds)
auto-update = download
auto-update-channel = stable

# --- Keybindings: tabs (Super = Cmd on macOS / Super on Linux) ---
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+]=next_tab
keybind = super+shift+[=previous_tab
keybind = super+physical:one=goto_tab:1
keybind = super+physical:two=goto_tab:2
keybind = super+physical:three=goto_tab:3
keybind = super+physical:four=goto_tab:4
keybind = super+physical:five=goto_tab:5
keybind = super+physical:six=goto_tab:6
keybind = super+physical:seven=goto_tab:7
keybind = super+physical:eight=goto_tab:8
keybind = super+physical:nine=goto_tab:9

# --- Keybindings: splits / panes ---
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+left=goto_split:left
keybind = super+shift+right=goto_split:right
keybind = super+shift+up=goto_split:up
keybind = super+shift+down=goto_split:down
keybind = super+shift+enter=toggle_split_zoom

# --- Keybindings: copy / selection / scrollback ---
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+shift+a=select_all
keybind = super+up=scroll_page_up
keybind = super+down=scroll_page_down
keybind = super+home=scroll_to_top
keybind = super+end=scroll_to_bottom
# super+shift+up/down drive pane navigation (see splits/panes above), so prompt
# jumps live on super+ctrl+up/down.
keybind = super+ctrl+up=jump_to_prompt:-1
keybind = super+ctrl+down=jump_to_prompt:1
