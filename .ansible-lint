---
# ansible-lint configuration.

exclude_paths:
  # CI workflow definitions are not Ansible content; keep ansible-lint's yaml
  # rule (e.g. truthy on GitHub's `on:` key) off them.
  - .github/

skip_list:
  # Roles deliberately use shared cross-role variables (e.g. omz_custom,
  # zsh_fragment_subdirs), user-facing config variables (p10k_*, git_*,
  # omz_bundled_plugins), and short register/set_fact names rather than a
  # per-role prefix. This is an intentional design choice, so the role-prefix
  # convention is disabled.
  - var-naming[no-role-prefix]
